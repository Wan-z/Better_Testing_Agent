# HTA reads credentials from the shared secrets file used across all agents:
#   ~/.config/trading-agents/secrets.env
#
# Required keys in that file:
#   AZURE_OPENAI_API_KEY      — Azure OpenAI service key
#   AZURE_OPENAI_BASE_URL     — e.g. https://azureaiapi.cloud.unc.edu/openai/v1/
#   AZURE_OPENAI_DEPLOYMENT   — deployment name, e.g. gpt-5.4
#
# Optional overrides (set here only if you need per-project values):
HTA_DEFAULT_ALPHA=0.05
HTA_DEFAULT_DRY_RUN=true
HTA_LOG_LEVEL=INFO
