# Copy this file to .env at the project root and fill in your values.
# .env is git-ignored and must never be committed.

# LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# --- Anthropic (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=<your Anthropic API key>
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (used when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=<your OpenAI API key>
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1  # override for Azure or other endpoints

# --- Optional overrides ---
# HTA_DEFAULT_ALPHA=0.05
# HTA_DEFAULT_DRY_RUN=false
# HTA_SESSION_TTL_DAYS=7
# HTA_LOG_LEVEL=INFO
